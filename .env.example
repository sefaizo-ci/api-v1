# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# Core
DATABASE_URL="postgresql://sefaizo:sefaizo_dev@localhost:5433/sefaizo_db"
JWT_SECRET="sefaizo_super_secret_change_en_prod"
JWT_EXPIRES_IN="7d"
API_KEY=
REDIS_URL="redis://localhost:6379"
PORT=3000
APP_NAME="Sefaizo API"


NOTIFICATIONS_DRY_RUN=true

# Dev only - forces OTP code to "0000" and skips notification sending
OTP_DEV_MODE=false

# Firebase (Push)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Meta WhatsApp
META_WHATSAPP_API_VERSION=v20.0
META_WHATSAPP_PHONE_NUMBER_ID=fake-phone-number-id
META_WHATSAPP_ACCESS_TOKEN=fake-meta-access-token

# MTarget SMS
MTARGET_SMS_BASE_URL=https://api.mtarget.local/sms/send
MTARGET_SMS_API_KEY=fake-mtarget-api-key
MTARGET_SMS_SENDER=SEFAIZO

# Appwrite Storage (backend upload)
APPWRITE_DRY_RUN=true
APPWRITE_ENDPOINT=https://fake-appwrite.local/v1
APPWRITE_PROJECT_ID=fake-project-id
APPWRITE_API_KEY=fake-api-key
APPWRITE_STORAGE_BUCKET_ID=fake-bucket-id
