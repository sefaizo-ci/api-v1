// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

enum Role {
  CLIENT
  PROFESSIONAL
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum BookingCancellationRequestStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum ServiceCategoryRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ServiceLocation {
  HOME
  SALON
  BOTH
}

enum OtpChannel {
  WHATSAPP
  SMS
}

enum OtpPurpose {
  REGISTRATION    
  LOGIN           
  PHONE_CHANGE    
  PIN_RESET       
}

model User {
  id          String   @id @default(uuid())
  phoneId     String   @unique
  phone       Phone    @relation(fields: [phoneId], references: [id], onDelete: Restrict)
  firstName   String
  lastName    String
  role        Role     @default(CLIENT)
  isVerified  Boolean  @default(false) 
  isActive    Boolean  @default(true)  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? 
  metadata    Json?

  pinHash          String?   
  pinFailCount     Int       @default(0)  
  pinBlockedUntil  DateTime? 

  otpCodes      OtpCode[]
  refreshTokens RefreshToken[]
  authLogs      AuthLog[]
  phoneRoles    PhoneRole[]

  professional     Professional?
  bookingsAsClient Booking[]     @relation("ClientBookings")
  reviewedServiceCategoryRequests ServiceCategoryRequest[] @relation("ServiceCategoryRequestReviewer")

  @@map("users")
}

model Phone {
  id         String      @id @default(uuid())
  number     String      @unique
  isVerified Boolean     @default(false)
  metadata   Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?

  roles      PhoneRole[]
  user       User?

  @@map("phones")
}

model PhoneRole {
  id        String   @id @default(uuid())
  phoneId   String
  phone     Phone    @relation(fields: [phoneId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phoneId, role])
  @@index([userId])
  @@map("phone_roles")
}

model OtpCode {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code        String     
  purpose     OtpPurpose
  channel     OtpChannel 
  isUsed      Boolean    @default(false)
  failCount   Int        @default(0)   
  blockedUntil DateTime? 
  metadata    Json?
  expiresAt   DateTime  
  createdAt   DateTime   @default(now())
  deletedAt   DateTime?

  @@map("otp_codes")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique 
  deviceInfo  String?  
  ipAddress   String?
  isRevoked   Boolean  @default(false)
  expiresAt   DateTime 
  platform    String?  
  metadata    Json?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())
  deletedAt   DateTime?

  @@map("refresh_tokens")
}

model AuthLog {
  id        String   @id @default(uuid())
  userId    String?  
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  event     String   
  channel   String?  
  ipAddress String?
  deviceInfo String?
  metadata  Json?    
  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@map("auth_logs")
}


model Professional {
  id          String          @id @default(uuid())
  userId      String          @unique
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  agencyName  String          
  bio         String?
  avatarUrl   String?
  location    ServiceLocation @default(BOTH) 
  address     String?         
  latitude    Float?
  longitude   Float?
  
  status      String          @default("PENDING") 
  isVerified  Boolean         @default(false)
  
  rating      Float           @default(0)
  reviewCount Int             @default(0)
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  
  metadata    Json?
  
  services       ServiceOffering[]
  serviceCategoryRequests ServiceCategoryRequest[]
  availabilities Availability[]
  gallery        GalleryItem[]
  bookings       Booking[]        @relation("ProfessionalBookings")
  reviews        Review[]

  @@map("professionals")
}

model ServiceOffering {
  id             String       @id @default(uuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  categoryId     String
  category       ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  name           String
  description    String?
  durationMin    Int          
  basePrice      Float        
  isActive       Boolean      @default(true)
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  
  metadata       Json?

  communeFees CommuneFee[]
  bookings    Booking[]

  @@unique([professionalId, name])
  @@index([categoryId])
  @@map("service_offerings")
}

model ServiceCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  metadata    Json?

  services    ServiceOffering[]
  requests    ServiceCategoryRequest[]

  @@unique([name])
  @@index([name])
  @@map("service_categories")
}

model ServiceCategoryRequest {
  id                    String                      @id @default(uuid())
  professionalId        String
  professional          Professional                @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  proposedName          String
  proposedDescription   String?
  status                ServiceCategoryRequestStatus @default(PENDING)
  reviewedByUserId      String?
  reviewedByUser        User?                       @relation("ServiceCategoryRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt            DateTime?
  reviewNote            String?
  approvedCategoryId    String?
  approvedCategory      ServiceCategory?            @relation(fields: [approvedCategoryId], references: [id], onDelete: SetNull)

  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  deletedAt             DateTime?
  metadata              Json?

  @@index([professionalId, status])
  @@index([status, createdAt])
  @@map("service_category_requests")
}

model CommuneFee {
  id                String          @id @default(uuid())
  serviceOfferingId String
  serviceOffering   ServiceOffering @relation(fields: [serviceOfferingId], references: [id], onDelete: Cascade)
  
  commune           String          
  travelFee         Float           
  isAvailable       Boolean         @default(true)
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  
  metadata          Json?

  @@unique([serviceOfferingId, commune])
  @@map("commune_fees")
}

model Availability {
  id             String       @id @default(uuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  
  dayOfWeek      Int          
  startTime      String       
  endTime        String       
  
  
  breakStartTime String?      
  breakEndTime   String?      
  
  
  status         String       @default("OPEN") 
  isActive       Boolean      @default(true)
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  
  metadata       Json?

  @@map("availabilities")
}

model Booking {
  id             String          @id @default(uuid())
  clientId       String
  client         User            @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  professionalId String
  professional   Professional    @relation("ProfessionalBookings", fields: [professionalId], references: [id], onDelete: Cascade)
  serviceId      String
  service        ServiceOffering @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  status         BookingStatus   @default(PENDING)
  scheduledAt    DateTime        
  durationMin    Int             
  totalPrice     Float           
  travelFee      Float           @default(0)
  commune        String          
  address        String?         
  clientNotes    String?
  
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  cancellationNote String?
  cancellationRequestStatus BookingCancellationRequestStatus @default(NONE)
  cancellationRequestedAt DateTime?
  cancellationReviewedAt DateTime?
  cancellationRequestReason String?
  
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  review Review?

  @@map("bookings")
}

model Review {
  id             String       @id @default(uuid())
  bookingId      String       @unique
  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  
  rating         Int          
  comment        String?
  
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("reviews")
}

model GalleryItem {
  id             String       @id @default(uuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  
  imageUrl       String       
  caption        String?
  category       String?      
  order          Int          @default(0)
  isPublic       Boolean      @default(true)
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  
  metadata       Json?

  @@map("gallery_items")
}
