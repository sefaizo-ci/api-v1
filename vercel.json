{
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/[...path]"
    },
    {
      "source": "/health",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api-docs",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api-docs/:path*",
      "destination": "/api/[...path]"
    }
  ]
}
