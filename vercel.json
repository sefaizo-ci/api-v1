{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].ts": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/[...path]"
    },
    {
      "source": "/health",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api-docs",
      "destination": "/api/[...path]"
    },
    {
      "source": "/api-docs/:path*",
      "destination": "/api/[...path]"
    }
  ]
}
