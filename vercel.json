{
  "buildCommand": "npx prisma generate",
  "functions": {
    "api/[...path].ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/[...path]"
    },
    {
      "source": "/:path*",
      "destination": "/api/[...path]"
    }
  ]
}
